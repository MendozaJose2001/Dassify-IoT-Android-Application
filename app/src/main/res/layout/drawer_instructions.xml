<?xml version="1.0" encoding="utf-8"?>
<!--
    Question Drawer Layout (instructions)
    Displays service indicators, real-time list of resolved targets and sensor source controls.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_instructions"
    android:layout_width="300dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#012854">

    <!-- Title above indicators -->
    <TextView
        android:id="@+id/services_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/available_services"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <!-- GPS Indicator using compound drawable with AppCompat -->
    <TextView
        android:id="@+id/gps_indicator_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/gps_label"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:drawableStartCompat="@drawable/circle_red"
        android:drawablePadding="12dp"
        android:gravity="center_vertical"
        android:padding="8dp" />

    <!-- Network Indicator using compound drawable with AppCompat -->
    <TextView
        android:id="@+id/network_indicator_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/network_label"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:drawableStartCompat="@drawable/circle_red"
        android:drawablePadding="12dp"
        android:gravity="center_vertical"
        android:padding="8dp" />

    <!-- Targets Indicator using compound drawable with AppCompat -->
    <TextView
        android:id="@+id/targets_indicator_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/targets_label"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:drawableStartCompat="@drawable/circle_red"
        android:drawablePadding="12dp"
        android:gravity="center_vertical"
        android:padding="8dp" />

    <!-- Title for real-time targets list -->
    <TextView
        android:id="@+id/targets_list_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/resolved_targets"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:textStyle="bold" />

    <!-- Scrollable container for real-time targets -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp">

        <LinearLayout
            android:id="@+id/targets_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp" />
    </ScrollView>

    <!-- ───────────────────────────────────────────────────── -->
    <!-- Sensor Source Selection (moved to instructions)       -->
    <!-- ───────────────────────────────────────────────────── -->

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="#40FFFFFF" />

    <TextView
        android:id="@+id/sensor_source_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sensor_source_title"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/sensor_source_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sensor_source_description"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:paddingBottom="8dp" />

    <RadioGroup
        android:id="@+id/sensor_source_radio_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radio_internal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sensor_source_internal"
            android:textColor="@android:color/white"
            android:checked="true"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

        <RadioButton
            android:id="@+id/radio_external"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sensor_source_external"
            android:textColor="@android:color/white"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />
    </RadioGroup>

    <TextView
        android:id="@+id/bluetooth_status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bluetooth_status_disconnected"
        android:textColor="#FF3131"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <!-- ───────────────────────────────────────────────────── -->
    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:background="#40FFFFFF" />

    <!-- Sección de Testing/Debug -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Testing Controls"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp" />

    <!-- Indicador de Acelerómetro -->
    <TextView
        android:id="@+id/accel_indicator_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Accelerometer"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:drawablePadding="8dp"
        android:gravity="center_vertical"
        android:padding="16dp" />

    <!-- Switch del Acelerómetro -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Enable Accelerometer"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_accelerometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true" />
    </LinearLayout>

    <!-- Modo actual (ACTIVE/STANDBY) -->
    <TextView
        android:id="@+id/accel_mode_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mode: STANDBY (event-driven)"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:padding="16dp"
        android:paddingTop="4dp" />

</LinearLayout>